<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>


<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:id="root"
            prefWidth="1280.0"
            prefHeight="720.0"
            fx:controller="utng.biblioteca.Controllers.MainController">

    <top>

        <fx:include source="components/TopBar.fxml" />

    </top>

    <left>

        <fx:include source="components/Sidebar.fxml"/>

    </left>

    <center>

        <ScrollPane fx:id="contentScrollPane"
                    fitToWidth="true"
                    fitToHeight="true"
                    pannable="true"
                    hbarPolicy="AS_NEEDED"
                    vbarPolicy="AS_NEEDED">

            <content>

                <StackPane fx:id="contentContainer"
                           prefWidth="1000.0"
                           prefHeight="650.0"/>

            </content>

        </ScrollPane>

    </center>

</BorderPane>